# ─── Supabase (Client — safe to bundle) ──────────────────────────────────────
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Tink (Client — safe to bundle) ──────────────────────────────────────────
EXPO_PUBLIC_TINK_CLIENT_ID=your-tink-client-id-here

# ─── Demo / Dev flags ─────────────────────────────────────────────────────────
# Set to 'true' to bypass Tink API and use realistic mock data (dev only)
EXPO_PUBLIC_DEMO_BANK_MODE=false
# Set to 'true' to bypass real IAP and use mock purchases (dev only)
EXPO_PUBLIC_MOCK_IAP=false

# ─── Supabase Edge Function Secrets (NEVER in client bundle) ─────────────────
# Set via: supabase secrets set KEY=value
#
# TINK_CLIENT_SECRET=your-tink-client-secret        ← Tink Console
# EXPO_ACCESS_TOKEN=your-expo-access-token          ← expo.dev/accounts/[user]/settings/access-tokens
# APPLE_SHARED_SECRET=your-apple-shared-secret      ← App Store Connect → App → In-App Purchases
# GOOGLE_SERVICE_ACCOUNT_JSON='{...}'               ← Google Play Console → Setup → API access
