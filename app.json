{
  "expo": {
    "name": "SubTrack",
    "slug": "SubTrack",
    "version": "1.0.0",
    "scheme": "subtrack",
    "orientation": "portrait",
    "icon": "./assets/subtrack_icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/subtrack_icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.brave.blandness619.SubTrack",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Log in to SubTrack securely with Face ID",
        "NSCalendarsFullAccessUsageDescription": "SubTrack needs calendar access to create and manage subscription renewal reminders.",
        "NSCalendarsWriteOnlyAccessUsageDescription": "SubTrack needs calendar access to add subscription renewal dates to your calendar."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/subtrack_icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.brave.blandness619.SubTrack"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "color": "#6750A4"
        }
      ],
      [
        "expo-calendar",
        {
          "calendarPermission": "SubTrack needs calendar access to add subscription renewal dates."
        }
      ],
      "react-native-iap"
    ],
    "extra": {
      "eas": {
        "projectId": "a2910967-7c4c-40b2-8632-772d177ea086"
      }
    },
    "owner": "brave.blandness619"
  }
}
